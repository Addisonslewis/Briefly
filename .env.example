# Database
DATABASE_URL=postgresql://briefly:briefly@localhost:5432/briefly_dev

# Encryption (32-byte hex string for AES-256-GCM)
ENCRYPTION_KEY=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# X (Twitter) OAuth 2.0
X_CLIENT_ID=
X_CLIENT_SECRET=

# LinkedIn OAuth 2.0
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Anthropic (categorization + synthesis)
ANTHROPIC_API_KEY=

# Feed provider: "socialdata" (default) or "twitter" (official X API v2)
FEED_PROVIDER=socialdata
# Required when FEED_PROVIDER=socialdata
SOCIALDATA_API_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=digest@briefly.app

# Cron Security
CRON_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Subscriptions (set "true" to enforce paid subscriptions)
SUBSCRIPTIONS_ENABLED=false
# Public mirror used by the client/pricing UI
NEXT_PUBLIC_SUBSCRIPTIONS_ENABLED=false

# Admin (for grant/revoke free plan endpoints)
ADMIN_SECRET=

# Admin emails (comma-separated). First entry receives the daily digest status email.
ADMIN_EMAILS=
